# SpendScout Backend — Environment Variables
# Copy this to .env and fill in your values. NEVER commit .env to git.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ── Database (SQLite for dev, swap for Postgres on prod) ─────────────────────
DATABASE_PATH=./data/spendscout.db

# ── Anthropic API ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Email (Resend — https://resend.com) ──────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=audit@spendscout.credex.rocks
EMAIL_FROM_NAME=SpendScout by Credex

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=50

# ── Misc ──────────────────────────────────────────────────────────────────────
# Secret for signing shareable audit tokens (generate with: openssl rand -base64 32)
SHARE_TOKEN_SECRET=change_me_in_production
